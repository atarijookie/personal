# Postgres connection (used by sensor_tcp_ingest.py)
PGHOST=localhost
PGPORT=5432
PGUSER=sensors
PGPASSWORD=srosnes
PGDATABASE=sensors

# TCP server bind
LISTEN_HOST=0.0.0.0
LISTEN_PORT=22222

# Runtime paths (used by run_sensor_server.sh)
VENV_DIR=.venv
SERVER_SCRIPT=sensor_tcp_ingest.py
PID_FILE=sensor_tcp_ingest.pid
LOG_FILE=sensor_tcp_ingest.log

# Flask API server
API_SCRIPT=sensor_api_server.py
API_PID_FILE=sensor_api_server.pid
API_LOG_FILE=sensor_api_server.log
API_HOST=0.0.0.0
API_PORT=20000
API_THREADS=4
